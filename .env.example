# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ANTHROPIC_API_KEY=sk-ant-api03-...
PROGRAM_ID=7AHMKtvPuZ6yKdWtWD1kC6kgPkEgooeBBtrmUrVc2teU

# ── Solana RPC (get a free key at helius.dev) ─────────────────────────────────
RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ── Security: generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=64_char_hex_string_here

# ── AgentB keypair (optional — auto-generated on first run and saved to users/.agent-b.json)
# To lock it permanently, paste the JSON array printed at startup:
# AGENT_B_KEYPAIR=[1,2,3,...,64]

# ── x402 server notifications (optional — Telegram chatId to receive alerts)
X402_NOTIFY_CHAT=
