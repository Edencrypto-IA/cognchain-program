# ============================================================
# CONGCHAIN — Environment Variables Template
# Copy this file to .env and fill in your values
#
# ⚠️ NUNCA commitar este arquivo. .env já está no .gitignore.
#    SOLANA_PRIVATE_KEY é array JSON da chave privada (devnet).
#    Se a chave vazar em qualquer momento, revogar imediatamente
#    via `solana-keygen new` e fazer git history rewrite se já
#    tiver sido commitada (verifique: git log --all --full-history -- .env).
# ============================================================

# Database
# Provider REAL: PostgreSQL (prisma/schema.prisma está hardcoded como
# postgresql). Para dev local é necessário um Postgres rodando,
# por exemplo via Docker:
#   docker run --name congchain-pg -e POSTGRES_PASSWORD=postgres \
#     -e POSTGRES_DB=congchain -p 5432:5432 -d postgres:16
# Em produção (Railway) use a connection string fornecida pelo serviço.
DATABASE_PROVIDER=postgresql
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/congchain

# Wallet Agent alert history persistence
# Default is memory. Use database only after the adapter phase is enabled.
WALLET_AGENT_ALERT_HISTORY_STORAGE=memory
# Keep disabled until the Prisma schema is migrated in the target environment.
WALLET_AGENT_ALERT_DATABASE_ADAPTER=disabled
# Optional dedicated Postgres URL for Wallet Agent alert history.
# WALLET_AGENT_ALERTS_DATABASE_URL=postgresql://user:pass@host:5432/dbname
# Declared retention window only. Deletion APIs are introduced in a later phase.
WALLET_AGENT_ALERT_HISTORY_RETENTION_DAYS=180

# ── AI Providers ─────────────────────────────────────────────
# Chaves de API de provedores de IA. Manter apenas em Railway/.env,
# NUNCA expor com prefixo NEXT_PUBLIC_.

# OpenAI — usado em: ai.router.ts (GPT), chat/stream, forge/*, mythos/test-chat,
#   pay/intelligence, commerce/product-finder
OPENAI_API_KEY=                 # platform.openai.com/api-keys
OPENAI_VISION_MODEL=gpt-4o-mini # Rota de visão (mythos/test-chat, html-artifact)

# Anthropic (Claude) — usado em: ai.router.ts, chat/stream, forge/*,
#   forge/inline-edit, mythos/html-artifact, pay/intelligence,
#   commerce/product-finder
ANTHROPIC_API_KEY=              # console.anthropic.com

# Google Gemini — usado em: ai.router.ts, chat/stream, forge/*
GEMINI_API_KEY=                 # aistudio.google.com/apikey

# DeepSeek — usado em: ai.router.ts, chat/stream, forge/*,
#   mythos/deepseek-orchestrator
DEEPSEEK_API_KEY=               # platform.deepseek.com/api_keys
DEEPSEEK_MODEL=                 # opcional, default: deepseek-v4-flash

# ── NVIDIA NIM (integrate.api.nvidia.com) ────────────────────
# Chave principal NVIDIA (Llama 3.3 + todos os modelos via
# NvidiaConfiguredRouteHandler no ai.router.ts)
NVIDIA_API_KEY=                 # build.nvidia.com → Get API Key (free)

# Chaves dedicadas por modelo gratuito (GLM/MiniMax/Qwen usam key própria
# no ai.router.ts e em chat/stream + forge/chat)
NVIDIA_GLM_KEY=                 # z-ai/glm4.7
NVIDIA_MINIMAX_KEY=             # minimaxai/minimax-m2.7
NVIDIA_QWEN_KEY=                # qwen/qwen3-next-80b-a3b-instruct

# Base URL opcional (default: https://integrate.api.nvidia.com/v1)
NVIDIA_BASE_URL=

# Overrides de modelo NVIDIA (todos opcionais, com fallback hardcoded).
# Usados em: ai.router.ts, chat/stream, mythos/test-chat, mythos/html-artifact
NVIDIA_MODEL_NEMOTRON_SUPER=    # default: nvidia/nemotron-3-super-120b-a12b
NVIDIA_MODEL_DEEPSEEK_V4=       # default: deepseek-ai/deepseek-v3.1
NVIDIA_MODEL_SEED=              # default: bytedance/seed-oss-36b-instruct
NVIDIA_MODEL_QWEN35=            # default: qwen/qwen3-235b-a22b-instruct-2507
NVIDIA_MODEL_KIMI=              # default: moonshotai/kimi-k2-instruct
NVIDIA_MODEL_MIXTRAL=           # default: mistralai/mixtral-8x22b-instruct-v0.1
NVIDIA_MODEL_MISTRAL_LARGE=     # default: mistralai/mistral-large
NVIDIA_MODEL_GPT_OSS_120B=      # default: openai/gpt-oss-120b
NVIDIA_MODEL_GEMMA4=            # default: google/gemma-3-27b-it
NVIDIA_MODEL_GEMMA3N_E2B=       # default: google/gemma-3n-e2b-it
NVIDIA_MODEL_PHI4=              # default: microsoft/phi-4-mini-instruct

# Rota de artifact HTML do Mythos
MYTHOS_HTML_ARTIFACT_PROVIDER=nvidia
MYTHOS_HTML_NVIDIA_MODEL=openai/gpt-oss-120b

# ── Solana ───────────────────────────────────────────────────
# ⚠️ Array JSON da chave privada, ex: [41,95,...,77] — devnet only!
SOLANA_PRIVATE_KEY=
SOLANA_PUBLIC_KEY=              # devnet wallet public key
SOLANA_RPC_URL=                 # https://devnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com
HELIUS_API_KEY=                 # Mythos Solana console (read-only)
SOLSCAN_API_KEY=                # Solscan Pro API (wallet/token metadata)
SOLSCAN_API_BASE=https://pro-api.solscan.io/v2.0

# Commerce / Product Finder
# Server-side Mercado Livre client credentials for Product Finder.
ML_APP_ID=
ML_CLIENT_SECRET=

# External Data / Financial Assistant
# Keep real keys only in Railway/.env. Never expose these with NEXT_PUBLIC_.
TRANSPARENCIA_KEY=              # Portal da Transparencia
BRAPI_KEY=                      # B3/Brazilian stock market data via brapi.dev
FED_API_KEY=                    # Federal Reserve Economic Data / FRED
ALPHA_VANTAGE_KEY=              # Global equities, forex, and technical indicators
COINGECKO_API_KEY=              # Optional CoinGecko market data key
MAPBOX_KEY=                     # Optional premium maps/geocoding
OPENALEX_KEY=                   # Optional academic/research metadata

# ── Auth (NextAuth / Social) ─────────────────────────────────
GOOGLE_CLIENT_ID=               # NextAuth Google provider (opcional)
GOOGLE_CLIENT_SECRET=

# ── CORS / API access control ────────────────────────────────
# Lista de origens permitidas para /api/*. Se vazio, o middleware
# libera Access-Control-Allow-Origin: * (modo aberto — defina para
# travar em produção). Controlado por src/middleware.ts.
ALLOWED_ORIGINS=

# ── Public (exposed to browser — use proxy, not direct key) ──
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Production Railway:
# NEXT_PUBLIC_BASE_URL=https://cognchain-program-production.up.railway.app
NEXT_PUBLIC_SOLANA_RPC_URL=/api/rpc   # Points to server-side RPC proxy

# ── Token Budget Caps (USD/month) ────────────────────────────
BUDGET_CLAUDE_USD=5             # Claude Opus — expensive, use sparingly
BUDGET_GPT_USD=10               # GPT-4o — general purpose
BUDGET_GEMINI_USD=5             # Gemini Flash — bulk/summaries
BUDGET_DEEPSEEK_USD=5           # DeepSeek V3 — code/reasoning
# NVIDIA Llama: free tier, no cap needed

# ── ZK Proof ─────────────────────────────────────────────────
ZK_MVP_ENABLED=true
ZK_MVP_MODE=simulated           # simulated | real (real requires: bun run zk:build)
